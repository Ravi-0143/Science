        }
        lines {
          text: "      oneLiner: \'Living, enucleate channels for bulk sugar flow\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      structure: \'Long, tube-like cells arranged end-to-end. At maturity, they lose their nucleus, ribosomes, vacuoles, and cytoskeleton to create an unobstructed pathway for sugar sap.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      keyFact: \'They are living cells yet lack a nucleus and ribosomes. Their end-walls are modified into sieve plates with large pores, allowing cytoplasmic continuity.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      stats: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
