        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // 3D Stem draw logic"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const draw3DStem = ("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx: CanvasRenderingContext2D,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      time: number,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      angle: number,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rotateX: number,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      day: boolean"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const centerX = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const centerY = 30;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const rStem = 110;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const hStem = 160;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Scale height based on 3D tilt"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const tiltRad = (rotateX * Math.PI) / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const cosT = Math.cos(tiltRad);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const sinT = Math.sin(tiltRad);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Colors reflecting light/dark mode"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const colors = {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        bark: day ? \'#5C7A58\' : \'#2A4430\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        barkBorder: day ? \'#3B5438\' : \'#142B1A\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        cortex: day ? \'#A7D49B\' : \'#3E5C38\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        phloem: day ? \'#6BB4D6\' : \'#2B5775\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        cambium: day ? \'#10B981\' : \'#34D399\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        xylem: day ? \'#F59E0B\' : \'#D97706\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        pith: day ? \'#F3EACF\' : \'#2D281D\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        highlight: day ? \'rgba(255,255,255,0.7)\' : \'rgba(52, 211, 153, 0.4)\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      };"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Draw shadow at bottom"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.beginPath();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.ellipse(centerX, centerY + hStem, rStem, rStem * sinT, 0, 0, Math.PI * 2);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.fillStyle = day ? \'rgba(0, 0, 0, 0.08)\' : \'rgba(0, 0, 0, 0.55)\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.fill();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Draw cylinder side/bark"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.beginPath();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.ellipse(centerX, centerY + hStem, rStem, rStem * sinT, 0, 0, Math.PI, false);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.lineTo(centerX + rStem, centerY);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.ellipse(centerX, centerY, rStem, rStem * sinT, 0, 0, Math.PI, true);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.lineTo(centerX - rStem, centerY + hStem);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.fillStyle = colors.bark;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.strokeStyle = colors.barkBorder;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.lineWidth = 1.5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.fill();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.stroke();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Draw the rotating sliced-wedge inside"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // We will draw the concentric vascular layers"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const layers = ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        { name: \'Epidermis & Cortex\', r: 110, fill: colors.cortex, desc: \'Outer protection and tissue support.\' },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        { name: \'Phloem\', r: 85, fill: colors.phloem, desc: \'Conducts sugars made in leaves bidirectional.\' },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        { name: \'Vascular Cambium\', r: 70, fill: colors.cambium, strokeOnly: true, desc: \'Active cell divider building new wood.\' },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        { name: \'Xylem\', r: 64, fill: colors.xylem, desc: \'Dead conduits transporting water under high tension.\' },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        { name: \'Central Pith\', r: 35, fill: colors.pith, desc: \'Soft storage parenchymal core.\' },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Render concentric ellipses"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      layers.forEach((layer) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.beginPath();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.ellipse(centerX, centerY, layer.r, layer.r * sinT, 0, 0, Math.PI * 2);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (layer.strokeOnly) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.strokeStyle = layer.fill;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.lineWidth = 3;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.shadowColor = layer.fill;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.shadowBlur = day ? 4 : 12;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.stroke();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.shadowBlur = 0; // reset"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.fillStyle = layer.fill;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.strokeStyle = day ? \'rgba(0,0,0,0.1)\' : \'rgba(255,255,255,0.08)\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.lineWidth = 1;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.fill();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.stroke();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Draw vascular bundle wedges radiating outward (pie-slices)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const numBundles = 10;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      for (let i = 0; i < numBundles; i++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const theta = (i * Math.PI * 2) / numBundles + angle;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const xOuter = centerX + Math.cos(theta) * 85;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const yOuter = centerY + Math.sin(theta) * 85 * sinT;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const xInner = centerX + Math.cos(theta) * 45;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
