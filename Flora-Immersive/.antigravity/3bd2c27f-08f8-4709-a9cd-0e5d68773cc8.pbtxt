        lines {
          text: "      name: \'Phloem Parenchyma\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      status: \'living\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      oneLiner: \'Nutrient reservoir and lateral pathway cells\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      structure: \'Elongated, living cells with thin cellulosic walls. They store starch, resins, latex, and organic compounds, and facilitate slow lateral nutrient diffusion.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      keyFact: \'Absent in monocots, but highly developed in dicots where they play a crucial role in maintaining tissue hydration and pressure flow balances.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      stats: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
