          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      name: \'Companion Cells\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      status: \'living\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      oneLiner: \'The metabolic engine powering phloem loading\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      structure: \'Highly specialized, nucleated parenchyma cells tightly coupled to sieve-tube elements via dense plasmodesmata. Packed with mitochondria and transport proteins.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      keyFact: \'They perform all necessary transcription, translation, and energy generation for the sieve-tube elements, actively loading sucrose against concentration gradients.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      stats: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        [\'Cellular State\', \'Living, hyper-metabolic\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        [\'Primary Function\', \'Active sucrose loading & unloading\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        [\'Mitochondria\', \'Abundant (high ATP production)\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        [\'Connection\', \'Dense plasmodesmatal channels\']"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
