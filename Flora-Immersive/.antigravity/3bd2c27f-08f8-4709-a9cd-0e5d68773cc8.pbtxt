        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "export const STORY_STEPS: StoryStep[] = ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: 1,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    title: \'The Vascular Stem Architecture\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    subtitle: \'Vascular Bundle Cross-Section\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    narration: \'Step inside the stem of an angiosperm. The vascular bundles are arranged in a ring, acting as the structural columns and primary transport highways of the plant. Inside each bundle, Xylem occupies the inner region, Phloem occupies the outer region, and they are divided by the active, dividing cell layer of the Vascular Cambium.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    focus: \'stem\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    xylemVal: 40,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    phloemVal: 40,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraZoom: 1.0,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraRotateX: 15,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraRotateY: -20"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: 2,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    title: \'Xylem: The Water Highway\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    subtitle: \'Hollow, Dead Conduits Operating Under Tension\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    narration: \'Deep within the stem lies the Xylem. To transport massive volumes of water efficiently, its conducting cells (Vessel Elements and Tracheids) undergo programmed cell death, completely digesting their protoplasts to form hollow, continuous microscopic pipelines. Their thick secondary walls are reinforced with rings or spirals of rigid lignin.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    focus: \'xylem\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    xylemVal: 55,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    phloemVal: 20,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraZoom: 1.6,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraRotateX: 30,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraRotateY: -35"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: 3,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    title: \'The Transpiration Pull Engine\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    subtitle: \'Cohesion-Tension Theory in Action\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    narration: \'How does water reach the top of a 300-foot tree without a pump? It is pulled by the sun! Water vapor evaporates out of leaf stomata (Transpiration), creating negative pressure. Thanks to the hydrogen bonding of water, water molecules exhibit strong Cohesion (sticking together) and Adhesion (sticking to hydrophilic xylem walls), forming an unbroken liquid column that is sucked upward.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    focus: \'transpiration\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    xylemVal: 85,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    phloemVal: 15,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraZoom: 1.8,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraRotateX: 0,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraRotateY: 0"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: 4,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    title: \'Phloem: The Nutrient Pipeline\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    subtitle: \'Living, Highly Regulated Bidirectional Translocation\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    narration: \'On the outer side of the bundle, the Phloem distributes the rich organic sugars made during photosynthesis. Unlike xylem, phloem elements (Sieve-Tube Elements) must remain alive to maintain active plasma membranes, allowing them to regulate osmotic pressure. Sieve-tube elements lose their nuclei to open the pathway, relying completely on metabolic support from adjacent Companion Cells.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    focus: \'phloem\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    xylemVal: 20,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    phloemVal: 60,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraZoom: 1.5,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraRotateX: -20,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraRotateY: 25"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: 5,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    title: \'The Pressure-Flow Engine\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    subtitle: \'Active Loading at Source, Unloading at Sink\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    narration: \'Sugar transport operates via the Munch Pressure-Flow Hypothesis. Companion cells actively load sucrose into the sieve-tubes at the Source (leaves). This hypertonic state draws water from the nearby xylem by osmosis, building extremely high turgor pressure. This high pressure pushes the sugary sap down toward the Sink (roots or developing fruits), where sugar is unloaded, and water recycles back.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    focus: \'translocation\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    xylemVal: 35,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    phloemVal: 90,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraZoom: 1.7,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraRotateX: -10,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraRotateY: 10"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: 6,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    title: \'Dual Hydraulic Integration\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    subtitle: \'Observe the Coupled Ecosystem in Real-Time\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    narration: \'Xylem and Phloem are not separate; they form a coupled hydraulic system. High transpiration speeds up xylem conduction, which in turn feeds water into the Phloem source for sugar loading. Adjust the sliders to see how environmental variables, stomatal openings, and leaf photosynthetic rates influence the dual highway flow speeds.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    focus: \'comparison\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    xylemVal: 60,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    phloemVal: 60,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraZoom: 1.2,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraRotateX: 5,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraRotateY: -5"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: 7,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    title: \'Diagnostic Knowledge Challenge\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    subtitle: \'Test Your Mastery\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    narration: \'You have completed the visual exploration of plant vascular anatomy! Let us put your understanding to the test. Our interactive diagnostic board challenges your ability to spot classic examiner traps, structural differences, and the physical principles governing xylem and phloem transport.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    focus: \'quiz\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    xylemVal: 30,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    phloemVal: 30,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraZoom: 1.0,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraRotateX: 0,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cameraRotateY: 0"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "export const EXAM_TRAPS: ExamTrap[] = ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    term: \'Companion Cells\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    belongs: \'Phloem Sieve Support\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    text: \'A favorite \"xylem component\" distractor in MCQs because of their support role. They are highly active, living, nucleated cells that belong strictly to the Phloem, doing the metabolic work for enucleate sieve tubes.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    term: \'Collenchyma\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    belongs: \'Simple Permanent Tissue\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    text: \'Frequently placed in vascular tissue options. Collenchyma is a simple tissue (one cell type) providing flexible support to young stems and petioles. Xylem is a complex tissue, and its support role is filled by Xylem Fibres.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    term: \'Tracheids vs Vessels\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    belongs: \'Gymnosperm vs Angiosperm\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    text: \'Examiners often claim vessels conduct in conifers. Gymnosperms lack vessel elements entirely; they rely solely on Tracheids for water transport. Angiosperms have BOTH vessels (highly efficient) and tracheids.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    term: \'Living vs Dead Conduction\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    belongs: \'Thermodynamics of Flow\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    text: \'Students often assume living cells conduct better. Xylem conduits MUST be dead; living cytoplasm would offer too much friction and resistance to water being sucked up under negative pressures of up to -30 atm!\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "export const QUIZ_QUESTIONS: QuizQuestion[] = ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    q: \'Which xylem cell type remains fully alive at functional maturity to carry out storage and lateral transport?\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    options: [\'Tracheids\', \'Vessel Elements\', \'Xylem Parenchyma\', \'Xylem Fibres\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    correct: 2,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
