          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      oneLiner: \'Protective, tough outer mechanical columns\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      structure: \'Highly elongated, thick-walled sclerenchymatous cells. They occur in clusters or bands on the outer periphery of the phloem, providing flexural strength.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      keyFact: \'The only dead component of phloem. Commercially known as \"bast fibres,\" they are harvested from plants like flax, hemp, and jute to weave high-strength ropes and linens.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      stats: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
